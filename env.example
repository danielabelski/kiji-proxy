# fill in the keys and rename the file to .env (mv env.example .env)
OPENAI_API_KEY=sk-....
ANTHROPIC_API_KEY=sk-ant-....
GEMINI_API_KEY=AIza....
MISTRAL_API_KEY=....

# UI access control (HTTP Basic Auth) — for the Linux/server deployment.
# Protects the dashboard UI and the /api/* admin endpoints (mappings, dashboard,
# logs, stats, model/*, proxy/*). The LLM proxy routes (/v1, /v1beta), all
# /api/pii/* endpoints, and /api/health|/api/version stay open. Auth turns on
# automatically once BOTH username and password are set. Set
# KIJI_BASIC_AUTH_ENABLED=false to force it off even when credentials are set.
# KIJI_BASIC_AUTH_USERNAME=admin
# KIJI_BASIC_AUTH_PASSWORD=change-me

# Transparent Proxy Configuration
# TRANSPARENT_PROXY_ENABLED=true
# TRANSPARENT_PROXY_PORT=:8080
# TRANSPARENT_PROXY_CA_PATH=~/.kiji-proxy/certs/ca.crt
# TRANSPARENT_PROXY_KEY_PATH=~/.kiji-proxy/certs/ca.key
